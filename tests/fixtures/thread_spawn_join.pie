fn main() -> int:
    let w1: () => int -> fn() -> int:
        println("child1")
        return 0
    end
    let w2: () => int -> fn() -> int:
        println("child2")
        return 0
    end
    let h1: thread -> thread.spawn(w1)
    let h2: thread -> thread.spawn(w2)
    thread.join(h1)
    thread.join(h2)
    println("done")
    return 0
end
