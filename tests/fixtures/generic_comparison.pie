fn max[T](a: T, b: T) -> T:
    if a > b:
        return a
    else:
        return b
    end
end

fn min[T](a: T, b: T) -> T:
    if a < b:
        return a
    else:
        return b
    end
end

fn eq[T](a: T, b: T) -> bool:
    return a == b
end

fn main() -> int:
    val1: int -> max(10, 20)
    val2: int -> min(10, 20)
    val3: bool -> eq(42, 42)
    val4: bool -> eq(42, 17)
    print(val1)
    print(val2)
    print(val3)
    print(val4)
    return 0
end
