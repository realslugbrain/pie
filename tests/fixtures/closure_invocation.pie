fn apply(f: (int, int) => int, x: int, y: int) -> int:
    return f(x, y)
end

fn main():
    let add: (int, int) => int -> fn(a: int, b: int) -> int:
        return a + b
    end
    let mul: (int, int) => int -> fn(a: int, b: int) -> int:
        return a * b
    end
    let r1: int -> add(3, 4)
    print(r1)
    let r2: int -> mul(3, 4)
    print(r2)
    let x: int -> 10
    let add_x: (int) => int -> fn(a: int) -> int:
        return a + x
    end
    let r3: int -> add_x(5)
    print(r3)
    let r4: int -> apply(add, 10, 20)
    print(r4)
end
