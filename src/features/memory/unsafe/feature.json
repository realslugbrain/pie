{
  "id": "memory.unsafe",
  "name": "Unsafe Boundary",
  "group": "memory",
  "version": "0.1.0",
  "kind": "stmt",
  "deps": ["memory.borrow"],
  "tokens": ["PIE_TOK_UNSAFE", "PIE_TOK_RAW"],
  "keywords": ["unsafe", "raw"],
  "operators": ["&raw", "*raw", "*raw=", "raw+", "raw-"],
  "ast_nodes": ["PIE_AST_UNSAFE_BLOCK", "PIE_AST_RAW_PTR", "PIE_AST_RAW_STORE"],
  "type_kinds": ["PIE_TYPE_RAW_PTR"],
  "hooks": ["parse_stmt", "parse_prefix", "sema_stmt", "sema_expr", "unsafe_check", "lower_stmt", "lower_expr", "codegen_stmt", "codegen_expr"],
  "parse_hooks": {
    "stmt": ["pie_feature_unsafe_parse_stmt", "pie_feature_unsafe_parse_raw_store_stmt"],
    "expr_prefix": ["pie_feature_unsafe_parse_raw_addr_expr", "pie_feature_unsafe_parse_raw_deref_expr"]
  },
  "sema_hooks": {
    "stmt": ["pie_feature_unsafe_sema_stmt"],
    "expr": ["pie_feature_unsafe_sema_expr"]
  },
  "lower_hooks": {
    "stmt": ["pie_feature_unsafe_lower_stmt"],
    "expr": ["pie_feature_unsafe_lower_expr"]
  },
  "asm_hooks": {
    "stmt": ["pie_feature_unsafe_codegen_stmt"],
    "expr": ["pie_feature_unsafe_codegen_expr"]
  }
}
