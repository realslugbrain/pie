{
  "id": "declarations.functions",
  "name": "Functions",
  "group": "declarations",
  "version": "0.1.0",
  "kind": "stmt",
  "deps": ["declarations.bindings"],
  "tokens": ["PIE_TOK_FN", "PIE_TOK_RETURN"],
  "keywords": ["fn", "return"],
  "operators": [],
  "ast_nodes": ["PIE_AST_FUNCTION", "PIE_AST_RETURN"],
  "type_kinds": ["PIE_TYPE_FUNCTION"],
  "hooks": ["parse_decl", "parse_stmt", "sema_decl", "lower_decl", "codegen_decl"],
  "parse_hooks": {
    "top_level": ["pie_feature_functions_parse_top_level"],
    "stmt": ["pie_feature_functions_parse_return_stmt", "pie_feature_functions_parse_expr_stmt"],
    "expr_prefix": ["pie_feature_functions_parse_call_expr"]
  },
  "sema_hooks": {
    "stmt": ["pie_feature_functions_sema_stmt"],
    "expr": ["pie_feature_functions_sema_expr"]
  },
  "lower_hooks": {
    "stmt": ["pie_feature_functions_lower_stmt"],
    "expr": ["pie_feature_functions_lower_expr"]
  },
  "asm_hooks": {
    "stmt": ["pie_feature_functions_codegen_stmt"],
    "expr": ["pie_feature_functions_codegen_expr"]
  }
}
