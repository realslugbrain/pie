{
  "id": "declarations.structs",
  "name": "Structs",
  "group": "declarations",
  "version": "0.1.0",
  "kind": "feature",
  "deps": ["declarations.bindings", "declarations.functions"],
  "tokens": ["PIE_TOK_STRUCT", "PIE_TOK_NEW", "PIE_TOK_DOT"],
  "keywords": ["struct", "new"],
  "operators": ["."],
  "ast_nodes": ["PIE_AST_STRUCT", "PIE_AST_NEW", "PIE_AST_FIELD"],
  "type_kinds": ["PIE_TYPE_STRUCT"],
  "hooks": ["parse_top_level", "parse_expr_prefix", "parse_expr_infix", "parse_stmt", "sema_stmt", "sema_expr", "lower_stmt", "lower_expr", "codegen_stmt", "codegen_expr"],
  "parse_hooks": {
    "top_level": ["pie_feature_structs_parse_top_level"],
    "stmt": ["pie_feature_structs_parse_field_assign_stmt"],
    "expr_prefix": ["pie_feature_structs_parse_new_expr"],
    "expr_infix": ["pie_feature_structs_parse_field_expr"]
  },
  "sema_hooks": {
    "stmt": ["pie_feature_structs_sema_stmt"],
    "expr": ["pie_feature_structs_sema_expr"]
  },
  "lower_hooks": {
    "stmt": ["pie_feature_structs_lower_stmt"],
    "expr": ["pie_feature_structs_lower_expr"]
  },
  "asm_hooks": {
    "stmt": ["pie_feature_structs_codegen_stmt"],
    "expr": ["pie_feature_structs_codegen_expr"]
  }
}
